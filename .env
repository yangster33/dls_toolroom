# 是否开启"势"tab（展示DlsMoment.vue）
# true - 开启，false - 关闭
VITE_ENABLE_MOMENT_TAB=true

# 是否启用 Mock API（开发时）
# true - 使用本地 mock 数据，无需后端
# false - 请求代理到 Django 后端 (localhost:8000)
VITE_USE_MOCK=false

